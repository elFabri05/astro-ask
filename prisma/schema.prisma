// Change provider to "postgresql" and update url to port to Postgres/Supabase.
// chartData uses String (not Json) so it stays portable across both providers.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model BirthChart {
  id              String           @id @default(cuid())
  name            String?
  birthDate       String           // "YYYY-MM-DD", local
  birthTime       String           // "HH:mm", local
  placeLabel      String
  latitude        Float
  longitude       Float
  timezone        String           // IANA name, from resolveUtcInstant
  utcDateTime     String           // ISO 8601 UTC, frozen at write time
  chartData       String           // JSON.stringify(ChartData), frozen at write time
  createdAt       DateTime         @default(now())
  interpretations Interpretation[]
  transitCharts   TransitChart[]
  sessions        Session[]
}

model Interpretation {
  id             String        @id @default(cuid())
  chartId        String
  transitChartId String?       // set for a "transit" opener; null for "natal"
  type           String        // "natal" | "transit"
  content        String        // generated text from the LLM
  model          String        // which model produced it
  createdAt      DateTime      @default(now())
  chart          BirthChart    @relation(fields: [chartId], references: [id], onDelete: Cascade)
  transitChart   TransitChart? @relation(fields: [transitChartId], references: [id], onDelete: Cascade)
}

model TransitChart {
  id                String           @id @default(cuid())
  chartId           String
  transitInstantUtc String           // ISO 8601 UTC, the actual instant used for the ephemeris calc
  latitude          Float            // location used for the calc (override place, or natal as default)
  longitude         Float
  targetDate        String           // "YYYY-MM-DD", human-facing calendar date
  localTime         String?          // "HH:mm", human-facing; null when defaulted to noon
  timezone          String?          // IANA zone the local time was resolved in; null when defaulted
  placeLabel        String?          // human label of an overridden place; null when using natal location
  transitData       String           // JSON.stringify(TransitData), frozen
  createdAt         DateTime         @default(now())
  chart             BirthChart       @relation(fields: [chartId], references: [id], onDelete: Cascade)
  interpretations   Interpretation[]
  sessions          Session[]

  @@unique([chartId, transitInstantUtc, latitude, longitude])
}

model Session {
  id             String        @id @default(cuid())
  chartId        String
  transitChartId String?       // null = a natal session; set = a transit session
  title          String?       // auto-generated from first user question
  createdAt      DateTime      @default(now())
  chart          BirthChart    @relation(fields: [chartId], references: [id], onDelete: Cascade)
  transitChart   TransitChart? @relation(fields: [transitChartId], references: [id], onDelete: Cascade)
  messages       Message[]
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
